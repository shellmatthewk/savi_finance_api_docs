# VaultLine MVP Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# Connection string from your Postgres provider (Supabase, Neon, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/vaultline

# ===========================================
# REDIS (Rate Limiting)
# ===========================================
# Upstash Redis REST URL and token (recommended for Vercel)
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your-upstash-token

# ===========================================
# STRIPE (Billing)
# ===========================================
# Secret key (sk_test_... for dev, sk_live_... for prod)
STRIPE_SECRET_KEY=sk_test_xxx

# Publishable key (pk_test_... for dev, pk_live_... for prod)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs for Standard tier
STRIPE_PRICE_MONTHLY_STANDARD=price_xxx
STRIPE_PRICE_ANNUAL_STANDARD=price_xxx

# ===========================================
# AUTHENTICATION
# ===========================================
# Secret for signing JWTs (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Canonical app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# FINANCIAL DATA (Upstream Providers)
# ===========================================
# API key for EOD data provider (Open Exchange Rates, CoinGecko, etc.)
FINANCIAL_DATA_API_KEY=your-api-key-here

# Metals API key (metals.live)
METALS_API_KEY=your-metals-api-key

# GoldAPI key (goldapi.io) - fallback for precious metals
GOLDAPI_KEY=your-goldapi-key

# ===========================================
# ADMIN AUTHENTICATION
# ===========================================
# API key for admin endpoints (generate with: openssl rand -base64 32)
ADMIN_API_KEY=your-admin-api-key-here

# ===========================================
# ALERTING CONFIGURATION
# ===========================================
# Slack webhook URL for critical alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty integration key for critical incidents
PAGERDUTY_KEY=your-pagerduty-integration-key

# Alert email recipients (optional, future implementation)
ALERT_EMAIL_TO=alerts@yourcompany.com
ALERT_EMAIL_FROM=finflux-api@yourcompany.com

# ===========================================
# PROMETHEUS METRICS
# ===========================================
# Basic auth credentials for Prometheus scraping endpoint
PROMETHEUS_USER=prometheus
PROMETHEUS_PASS=your-prometheus-password

# ===========================================
# ERROR MONITORING (Future)
# ===========================================
# Note: Sentry integration pending Next.js 16 support
# Add SENTRY_DSN and NEXT_PUBLIC_SENTRY_DSN when available
